# ── Anthropic (Claude AI) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Airtable ───────────────────────────────────────────────────────────────────
# Run `npm run setup-airtable` once to create the base; it will print these values
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=app...
AIRTABLE_TABLE_NAME=Talent Profiles

# ── Resend (email) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
# The email address Resend will send FROM (must be verified in your Resend dashboard)
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── App ────────────────────────────────────────────────────────────────────────
# Public URL of your deployed app (used to build edit links in emails)
NEXT_PUBLIC_APP_URL=https://talent-connect.vercel.app
